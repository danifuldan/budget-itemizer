{
  "manifest_version": 3,
  "name": "Budget Itemizer",
  "version": "0.2.0",
  "description": "Capture receipts from any page and send to Budget Itemizer for parsing",
  "permissions": ["activeTab", "debugger", "storage", "scripting"],
  "host_permissions": ["http://localhost:*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
