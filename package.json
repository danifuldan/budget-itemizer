{
  "name": "budget-itemizer",
  "version": "0.3.1",
  "description": "Split and categorize online receipts for YNAB — free, local, and private.",
  "author": "danifuldan",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/danifuldan/budget-itemizer.git"
  },
  "homepage": "https://github.com/danifuldan/budget-itemizer",
  "bugs": {
    "url": "https://github.com/danifuldan/budget-itemizer/issues"
  },
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env --import tsx/esm index.ts",
    "dev": "tsx watch --env-file=.env index.ts",
    "dev:frontend": "vite",
    "build:frontend": "vite build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build && hdiutil attach src-tauri/target/release/bundle/dmg/*.dmg",
    "build:server": "node build-server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoke:fixtures": "tsx smoke/fixtures.ts",
    "smoke:use-path": "tsx smoke/use-path.ts",
    "smoke:fresh-install": "tsx smoke/fresh-install.ts",
    "smoke:personal": "tsx smoke/personal.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@yao-pkg/pkg": "^6.14.1",
    "esbuild": "^0.27.3",
    "fast-check": "^4.7.0",
    "happy-dom": "^20.9.0",
    "pdf-lib": "^1.17.1",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@actual-app/api": "^26.3.0",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "hono": "^4.6.16",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "undici": "^6.25.0",
    "ynab": "^2.6.0",
    "zod": "^3.24.1"
  }
}
